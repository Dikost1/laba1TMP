<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Laba1Avalonia.InputComponentDialog"
        Title="Добавить компонент"
        Width="350" Height="180"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15" Spacing="10">
        <TextBlock Text="Имя компонента:"/>
        <TextBox x:Name="NameBox" Watermark="Введите имя"/>
        <TextBlock Text="Тип (Изделие, Узел, Деталь):"/>
        <ComboBox x:Name="TypeCombo" SelectedIndex="0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="OkButton" Content="ОК" Click="OnOkClick"/>
            <Button x:Name="CancelButton" Content="Отмена" Click="OnCancelClick"/>
        </StackPanel>
    </StackPanel>
</Window>
