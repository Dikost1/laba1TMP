<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Laba1Avalonia"
        x:Class="Laba1Avalonia.InfoDialog"
        x:Name="Self"
        Width="350" Height="150"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15" Spacing="10" x:DataType="local:InfoDialog">
        <TextBlock x:Name="MessageText" Text="{Binding Message}" TextWrapping="Wrap"/>
        <Button x:Name="OkButton" Content="ОК" HorizontalAlignment="Right" Click="OnOkClick"/>
    </StackPanel>
</Window>
